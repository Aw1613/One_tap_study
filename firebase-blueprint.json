{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "Stores user profile information and current status.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Unique Firebase Auth ID" },
        "displayName": { "type": "string", "description": "User's display name" },
        "photoURL": { "type": "string", "description": "User's profile picture URL" },
        "email": { "type": "string", "description": "User's email" },
        "bio": { "type": "string", "description": "Short bio or study interests" },
        "hostel": { "type": "string", "description": "The hostel where the user resides" },
        "lastLocation": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Flare": {
      "title": "Study Flare",
      "description": "A real-time signal broadcasted by a student looking for study partners.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userPhoto": { "type": "string" },
        "subject": { "type": "string", "description": "The subject being studied" },
        "description": { "type": "string", "description": "Specific topic or goal" },
        "expiresAt": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "location": {
          "type": "object",
          "properties": {
            "latitude": { "type": "number" },
            "longitude": { "type": "number" }
          }
        },
        "hostel": { "type": "string", "description": "The hostel where the study session is happening" },
        "maxPartners": { "type": "number", "description": "Maximum number of partners requested" },
        "currentPartners": { "type": "number", "description": "Current number of partners who joined" },
        "active": { "type": "boolean" }
      },
      "required": ["userId", "subject", "expiresAt", "createdAt"]
    },
    "Friendship": {
      "title": "User Connection",
      "description": "Represents a friendship or connection between two students.",
      "type": "object",
      "properties": {
        "users": { "type": "array", "items": { "type": "string" }, "description": "Array of two user UIDs" },
        "createdAt": { "type": "string", "format": "date-time" },
        "status": { "type": "string", "enum": ["pending", "accepted"] }
      }
    },
    "Message": {
      "title": "Chat Message",
      "description": "A message sent within a study flare chat room.",
      "type": "object",
      "properties": {
        "flareId": { "type": "string" },
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "text": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["flareId", "senderId", "text", "createdAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile data"
    },
    "/flares/{flareId}": {
      "schema": "Flare",
      "description": "Active study flares"
    },
    "/friendships/{friendshipId}": {
      "schema": "Friendship",
      "description": "User connections"
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat messages for flares"
    }
  }
}
